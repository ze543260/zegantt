{
  "name": "zegantt",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josev/zegantt.git"
  },
  "main": "./dist/zegantt.umd.cjs",
  "module": "./dist/zegantt.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
